# Environment Configuration Template for Query Triage
# Copy this content to .env file and update values

NODE_ENV=development
PORT=5001

# MongoDB Connection
MONGO_URI=

# JWT Configuration (use same as csfaq)
JWT_SECRET=super_secret_jwt_key_change_me_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_change_me

# Client URL for CORS
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Local LLM Inference / OpenAI API (compatible with llama.cpp Qwen2.5)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Capacity thresholds
CAPACITY_WARNING_THRESHOLD=0.70
CAPACITY_CRITICAL_THRESHOLD=0.90
MAX_ACTIVE_CASES_PER_RESOLVER=10

# SLA Configuration
SLA_P0_RESPONSE_MINUTES=15
SLA_P0_RESOLUTION_HOURS=2
SLA_P1_RESPONSE_HOURS=1
SLA_P1_RESOLUTION_HOURS=4
SLA_P2_RESPONSE_HOURS=8
SLA_P2_RESOLUTION_HOURS=48
SLA_P3_RESPONSE_HOURS=48
SLA_P3_RESOLUTION_HOURS=120

# Threshold Configuration
DUPLICATE_SIMILARITY_THRESHOLD=0.90
MIN_AI_CONFIDENCE=0.70
MEDIUM_AI_CONFIDENCE=0.45