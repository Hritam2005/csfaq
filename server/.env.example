NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/knowledge_hub

# Cross-database auth for the query-triage microservice users.
# When a user is not found in the main DB above, the login endpoint will
# fall back to this database. Leave blank to disable the fallback.
TRIAGE_MONGO_URI=
TRIAGE_DB_NAME=csfaq_triage

# JWT Secrets
JWT_SECRET=super_secret_jwt_key_change_me_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_change_me

# CORS Client
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Storage Limits
UPLOAD_LIMIT=50mb

# External APIs
OPENAI_API_KEY=
REDIS_URL=

# Email Settings
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
